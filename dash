<!doctype html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>PhysioLution³ Dashboard</title>
  </head>
  <body>
    <div id="root"></div>
    <script type="module" src="/src/main.jsx"></script>
  </body>
</html>
{
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "@vitejs/plugin-react": "latest",
    "vite": "latest",
    "react": "latest",
    "react-dom": "latest",
    "lucide-react": "latest",
    "framer-motion": "latest"
  },
  "devDependencies": {}
}import { useState } from 'react'

export default function Dashboard() {
  const [data, setData] = useState({
    rightWeight: 70,
    rightReps: 12,
    leftWeight: 65,
    leftReps: 12,
  })

  const calculatePercentage = (reps) => {
    return (-1.4 * reps) + 95
  }

  const calc1RM = (weight, reps) => {
    if (!weight || !reps) return 0

    const percentage = calculatePercentage(reps)

    if (percentage <= 0) return 0

    return weight / (percentage / 100)
  }

  const calcLSI = (right, left) => {
    if (!right || !left) return 0

    const weaker = Math.min(right, left)
    const stronger = Math.max(right, left)

    return (weaker / stronger) * 100
  }

  const updateField = (field, value) => {
    setData((prev) => ({
      ...prev,
      [field]: Number(value),
    }))
  }

  const rightRM = calc1RM(data.rightWeight, data.rightReps)
  const leftRM = calc1RM(data.leftWeight, data.leftReps)
  const lsi = calcLSI(rightRM, leftRM)
  const deficit = 100 - lsi
  const weakerSide = rightRM === leftRM ? 'Ausgeglichen' : rightRM > leftRM ? 'Links' : 'Rechts'

  const getTrainingZones = (rm) => ({
    '90% Maximalkraft': (rm * 0.9).toFixed(1),
    '80% Kraftaufbau': (rm * 0.8).toFixed(1),
    '70% Hypertrophie': (rm * 0.7).toFixed(1),
    '60% Kraftausdauer': (rm * 0.6).toFixed(1),
  })

  const rightZones = getTrainingZones(rightRM)
  const leftZones = getTrainingZones(leftRM)

  const status = deficit > 15
    ? { label: 'Klinisch relevant', background: 'rgba(239,68,68,.14)', border: 'rgba(248,113,113,.35)' }
    : deficit > 10
      ? { label: 'Moderate Differenz', background: 'rgba(234,179,8,.14)', border: 'rgba(250,204,21,.35)' }
      : { label: 'Gute Symmetrie', background: 'rgba(16,185,129,.14)', border: 'rgba(52,211,153,.35)' }

  return (
    <main className="page" style={{
      minHeight: '100vh',
      color: 'white',
      padding: 28,
      background: 'linear-gradient(135deg, #020617 0%, #0f172a 50%, #1e293b 100%)'
    }}>
      <div style={{ maxWidth: 1180, margin: '0 auto', display: 'grid', gap: 28 }}>
        <section style={cardStyle}>
          <div style={{ display: 'flex', justifyContent: 'space-between', gap: 24, flexWrap: 'wrap' }}>
            <div>
              <div style={{ color: '#94a3b8', fontWeight: 800, letterSpacing: 2, textTransform: 'uppercase' }}>
                PhysioLution³
              </div>
              <h1 className="hero-title" style={{ fontSize: 44, margin: '8px 0 0', lineHeight: 1 }}>
                RM & Symmetrie Dashboard
              </h1>
              <p style={{ color: '#cbd5e1', fontSize: 18, marginTop: 14 }}>
                Standard-Rechner für 1RM, LSI und Trainingsgewichte.
              </p>
            </div>

            <div style={{
              background: 'rgba(16,185,129,.14)',
              border: '1px solid rgba(52,211,153,.25)',
              borderRadius: 24,
              padding: 20,
              maxWidth: 360
            }}>
              <div style={{ color: '#a7f3d0', fontWeight: 800, textTransform: 'uppercase', fontSize: 13 }}>
                Methode
              </div>
              <div style={{ fontWeight: 900, fontSize: 22, marginTop: 6 }}>
                nRM → 1RM
              </div>
              <p style={{ color: '#cbd5e1', marginBottom: 0 }}>
                %1RM = [-1,4 × Wiederholungen + 95]
              </p>
            </div>
          </div>
        </section>

        <section className="grid-two" style={{ display: 'grid', gridTemplateColumns: 'repeat(2, minmax(0, 1fr))', gap: 24 }}>
          <InputCard
            title="Rechte Seite"
            weight={data.rightWeight}
            reps={data.rightReps}
            rm={rightRM}
            onWeight={(value) => updateField('rightWeight', value)}
            onReps={(value) => updateField('rightReps', value)}
          />

          <InputCard
            title="Linke Seite"
            weight={data.leftWeight}
            reps={data.leftReps}
            rm={leftRM}
            onWeight={(value) => updateField('leftWeight', value)}
            onReps={(value) => updateField('leftReps', value)}
          />
        </section>

        <section className="grid-three" style={{ display: 'grid', gridTemplateColumns: 'repeat(3, minmax(0, 1fr))', gap: 20 }}>
          <ResultCard title="Schwächere Seite" value={weakerSide} subtitle="Automatische Erkennung" />
          <ResultCard title="Limb Symmetry Index" value={`${lsi.toFixed(1)}%`} subtitle="Zielwert häufig über 90%" />
          <ResultCard title="Defizit" value={`${deficit.toFixed(1)}%`} subtitle={status.label} customStyle={{
            background: status.background,
            borderColor: status.border
          }} />
        </section>

        <section style={cardStyle}>
          <h2 style={{ fontSize: 28, marginTop: 0 }}>Trainingsgewichte</h2>
          <div className="table-wrap">
            <table style={{ width: '100%', minWidth: 560 }}>
              <thead>
                <tr style={{ background: 'rgba(15,23,42,.85)' }}>
                  <th style={thStyle}>Trainingsziel</th>
                  <th style={thCenterStyle}>Rechts</th>
                  <th style={thCenterStyle}>Links</th>
                </tr>
              </thead>
              <tbody>
                {Object.keys(rightZones).map((key) => (
                  <tr key={key} style={{ borderTop: '1px solid rgba(148,163,184,.2)' }}>
                    <td style={tdStyle}>{key}</td>
                    <td style={tdCenterStyle}>{rightZones[key]} kg</td>
                    <td style={tdCenterStyle}>{leftZones[key]} kg</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </section>

        <section style={cardStyle}>
          <h2 style={{ fontSize: 28, marginTop: 0 }}>Bedienung für CrewMember³</h2>
          <div className="grid-three" style={{ display: 'grid', gridTemplateColumns: 'repeat(3, minmax(0, 1fr))', gap: 18 }}>
            <Step title="1. Gewicht eingeben" text="Rechte und linke Seite separat erfassen." />
            <Step title="2. Wiederholungen eingeben" text="Wiederholungen bis nahe Ausbelastung eintragen." />
            <Step title="3. Ergebnis nutzen" text="1RM, LSI, Defizit und Trainingsgewichte erscheinen sofort." />
          </div>
        </section>
      </div>
    </main>
  )
}

function InputCard({ title, weight, reps, rm, onWeight, onReps }) {
  return (
    <div style={cardStyle}>
      <h2 style={{ fontSize: 28, marginTop: 0 }}>{title}</h2>
      <p style={{ color: '#cbd5e1' }}>Gewicht & Wiederholungen</p>

      <div style={{ display: 'grid', gap: 18, marginTop: 22 }}>
        <label style={labelStyle}>
          Gewicht (kg)
          <input
            type="number"
            value={weight}
            onChange={(event) => onWeight(event.target.value)}
            style={inputStyle}
          />
        </label>

        <label style={labelStyle}>
          Wiederholungen
          <input
            type="number"
            value={reps}
            onChange={(event) => onReps(event.target.value)}
            style={inputStyle}
          />
        </label>

        <div style={{
          background: 'rgba(6,182,212,.12)',
          border: '1px solid rgba(103,232,249,.25)',
          borderRadius: 22,
          padding: 20
        }}>
          <div style={{ color: '#a5f3fc', fontWeight: 800, fontSize: 13, textTransform: 'uppercase' }}>
            1RM
          </div>
          <div style={{ fontSize: 44, fontWeight: 900, marginTop: 8 }}>
            {rm.toFixed(1)} kg
          </div>
        </div>
      </div>
    </div>
  )
}

function ResultCard({ title, value, subtitle, customStyle = {} }) {
  return (
    <div style={{ ...cardStyle, ...customStyle }}>
      <div style={{ color: '#94a3b8', fontWeight: 800, fontSize: 13, textTransform: 'uppercase', letterSpacing: 1 }}>
        {title}
      </div>
      <div style={{ fontSize: 38, fontWeight: 900, marginTop: 10 }}>{value}</div>
      <div style={{ color: '#cbd5e1', marginTop: 10 }}>{subtitle}</div>
    </div>
  )
}

function Step({ title, text }) {
  return (
    <div style={{
      background: 'rgba(15,23,42,.68)',
      border: '1px solid rgba(148,163,184,.22)',
      borderRadius: 20,
      padding: 20
    }}>
      <div style={{ fontWeight: 900, fontSize: 19 }}>{title}</div>
      <div style={{ color: '#cbd5e1', marginTop: 8 }}>{text}</div>
    </div>
  )
}

const cardStyle = {
  background: 'rgba(255,255,255,.09)',
  border: '1px solid rgba(255,255,255,.12)',
  borderRadius: 28,
  padding: 28,
  boxShadow: '0 24px 80px rgba(0,0,0,.28)',
  backdropFilter: 'blur(18px)'
}

const labelStyle = {
  display: 'grid',
  gap: 8,
  color: '#94a3b8',
  fontSize: 14,
  fontWeight: 700
}

const inputStyle = {
  width: '100%',
  background: '#0f172a',
  border: '1px solid rgba(148,163,184,.35)',
  borderRadius: 18,
  padding: '16px 18px',
  color: 'white',
  fontSize: 22,
  outline: 'none'
}

const thStyle = {
  textAlign: 'left',
  padding: 16,
  color: '#cbd5e1'
}

const thCenterStyle = {
  textAlign: 'center',
  padding: 16,
  color: '#cbd5e1'
}

const tdStyle = {
  padding: 16,
  fontWeight: 700
}

const tdCenterStyle = {
  padding: 16,
  fontWeight: 900,
  textAlign: 'center'
}

import React from 'react'
import { createRoot } from 'react-dom/client'
import './style.css'
import Dashboard from './Dashboard.jsx'

createRoot(document.getElementById('root')).render(
  <React.StrictMode>
    <Dashboard />
  </React.StrictMode>
)
